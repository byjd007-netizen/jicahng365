  "module1_html": "    <!-- Module 1: 热门关键词导航 -->\n    <section class=\"seo-tags-section\">\n      <div class=\"home-v2-container\">\n        <h3 class=\"seo-tags-title\">🔥 热门代理与跨境网络关键词导航</h3>\n        <div class=\"seo-tags-grid\">\n          <a href=\"airport/\" class=\"seo-tag-link\">机场推荐</a>\n          <a href=\"review/\" class=\"seo-tag-link\">机场评测</a>\n          <a href=\"network/\" class=\"seo-tag-link\">IPLC专线</a>\n          <a href=\"network/\" class=\"seo-tag-link\">IEPL线路</a>\n          <a href=\"tutorial/\" class=\"seo-tag-link\">Clash教程</a>\n          <a href=\"ai/\" class=\"seo-tag-link\">AI工具连通</a>\n          <a href=\"tutorial/\" class=\"seo-tag-link\">Shadowrocket教程</a>\n          <a href=\"tutorial/\" class=\"seo-tag-link\">v2rayNG配置</a>\n          <a href=\"ai/\" class=\"seo-tag-link\">ChatGPT登录</a>\n          <a href=\"avoid-scam/\" class=\"seo-tag-link\">机场跑路雷达</a>\n        </div>\n      </div>\n    </section>",
  "module2_html": "    <!-- Module 2: 知识百科入口 -->\n    <section class=\"wiki-entries-section\">\n      <div class=\"home-v2-container\">\n        <div class=\"home-v2-sec-header\">\n          <h2 class=\"home-v2-sec-title\">🌐 跨境网络知识百科词条</h2>\n        </div>\n        <div class=\"wiki-grid\">\n          <a href=\"articles/article-8.html\" class=\"wiki-card\">\n            <span class=\"wiki-card-q\">什么是 IPLC 专线？</span>\n            <span class=\"wiki-card-a\">IPLC是点对点跨国物理专线，内网传输不经过公网，完全绕过GFW，提供零丢包高稳定的终极访问体验。</span>\n            <span class=\"wiki-card-more\">阅读百科词条 &rarr;</span>\n          </a>\n          <a href=\"articles/article-8.html\" class=\"wiki-card\">\n            <span class=\"wiki-card-q\">什么是 IEPL 专线？</span>\n            <span class=\"wiki-card-a\">IEPL是国际以太网私网专线。提供同IPLC一致的免阻断稳定性，但属于二层以太网链路，调度和带宽扩容更为弹性。</span>\n            <span class=\"wiki-card-more\">阅读百科词条 &rarr;</span>\n          </a>\n          <a href=\"articles/article-8.html\" class=\"wiki-card\">\n            <span class=\"wiki-card-q\">什么是 BGP 中继线路？</span>\n            <span class=\"wiki-card-a\">BGP中转是机场入口部署多线服务器，自动适配联通、移动、电信用户，消除跨运营商跨省的高延迟与网络丢包。</span>\n            <span class=\"wiki-card-more\">阅读百科词条 &rarr;</span>\n          </a>\n          <a href=\"articles/article-6.html\" class=\"wiki-card\">\n            <span class=\"wiki-card-q\">机场晚上为什么慢？</span>\n            <span class=\"wiki-card-a\">晚高峰20-23点是公网国际出口拥堵期。普通直连线路受QoS限速丢包严重，只有专线中转网络能保障全天不限速。</span>\n            <span class=\"wiki-card-more\">阅读百科词条 &rarr;</span>\n          </a>\n        </div>\n      </div>\n    </section>",

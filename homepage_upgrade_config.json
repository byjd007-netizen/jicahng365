  "module1_html": "    <!-- Module 1: 热门关键词导航 -->\n    <section class=\"seo-tags-section\">\n      <div class=\"home-v2-container\">\n        <h3 class=\"seo-tags-title\">🔥 热门代理与跨境网络关键词导航</h3>\n        <div class=\"seo-tags-grid\">\n          <a href=\"airport/\" class=\"seo-tag-link\">机场推荐</a>\n          <a href=\"review/\" class=\"seo-tag-link\">机场评测</a>\n          <a href=\"network/\" class=\"seo-tag-link\">IPLC专线</a>\n          <a href=\"network/\" class=\"seo-tag-link\">IEPL线路</a>\n          <a href=\"tutorial/\" class=\"seo-tag-link\">Clash教程</a>\n          <a href=\"ai/\" class=\"seo-tag-link\">AI工具连通</a>\n          <a href=\"tutorial/\" class=\"seo-tag-link\">Shadowrocket教程</a>\n          <a href=\"tutorial/\" class=\"seo-tag-link\">v2rayNG配置</a>\n          <a href=\"ai/\" class=\"seo-tag-link\">ChatGPT登录</a>\n          <a href=\"avoid-scam/\" class=\"seo-tag-link\">机场跑路雷达</a>\n        </div>\n      </div>\n    </section>",
  "module2_html": "    <!-- Module 2: 知识百科入口 -->\n    <section class=\"wiki-entries-section\">\n      <div class=\"home-v2-container\">\n        <div class=\"home-v2-sec-header\">\n          <h2 class=\"home-v2-sec-title\">🌐 跨境网络知识百科词条</h2>\n        </div>\n        <div class=\"wiki-grid\">\n          <a href=\"articles/article-8.html\" class=\"wiki-card\">\n            <span class=\"wiki-card-q\">什么是 IPLC 专线？</span>\n            <span class=\"wiki-card-a\">IPLC是国际私有物理专线，内网传输完全绕过GFW，提供零丢包、低延迟且免阻断的终极访问体验。</span>\n            <span class=\"wiki-card-more\">阅读百科词条 &rarr;</span>\n          </a>\n          <a href=\"articles/article-9.html\" class=\"wiki-card\">\n            <span class=\"wiki-card-q\">如何防止真实 IP 泄露？</span>\n            <span class=\"wiki-card-a\">开启WebRTC禁用规则，启用安全DNS解析并使用防泄露代理规则，从根本上杜绝代理环境下的真实IP暴露风险。</span>\n            <span class=\"wiki-card-more\">阅读百科词条 &rarr;</span>\n          </a>\n          <a href=\"articles/article-7.html\" class=\"wiki-card\">\n            <span class=\"wiki-card-q\">什么是 Hysteria 2 协议？</span>\n            <span class=\"wiki-card-a\">Hysteria 2是基于UDP的超快速代理协议，采用独特的拥堵控制算法，能在高丢包和恶劣网络下跑满带宽速度。</span>\n            <span class=\"wiki-card-more\">阅读百科词条 &rarr;</span>\n          </a>\n          <a href=\"articles/article-6.html\" class=\"wiki-card\">\n            <span class=\"wiki-card-q\">如何彻底排查节点断流？</span>\n            <span class=\"wiki-card-a\">从本地DNS污染、宽带QoS限速、中转入口拥堵及客户端内核版本兼容性四个维度逐步排查断流及超时问题。</span>\n            <span class=\"wiki-card-more\">阅读百科词条 &rarr;</span>\n          </a>\n        </div>\n      </div>\n    </section>",
